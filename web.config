<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config for Bandersnatch Interactive Player hosted on IIS
  ============================================================
  Place this file in the ROOT of your IIS site (same folder as index.html).

  What this does:
    1. Adds MIME types for MKV, MP4, WebM, VTT so IIS will serve them.
    2. Disables request size limits so large video files can be served.
    3. Enables HTTP range requests (byte-range / seeking support in the browser).
    4. Sets default document to index.html.
-->
<configuration>

  <system.webServer>

    <!-- ── Default document ─────────────────────────────────────────────── -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ── MIME types ───────────────────────────────────────────────────── -->
    <!--
      IIS does NOT serve files with unknown MIME types by default.
      MKV is almost never in the default IIS list, so it must be added.
    -->
    <staticContent>
      <remove fileExtension=".mkv" />
      <mimeMap fileExtension=".mkv" mimeType="video/x-matroska" />

      <remove fileExtension=".mp4" />
      <mimeMap fileExtension=".mp4" mimeType="video/mp4" />

      <remove fileExtension=".webm" />
      <mimeMap fileExtension=".webm" mimeType="video/webm" />

      <remove fileExtension=".vtt" />
      <mimeMap fileExtension=".vtt" mimeType="text/vtt" />

      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />

      <remove fileExtension=".css" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
    </staticContent>

    <!-- ── HTTP range requests (byte-range seeking) ─────────────────────── -->
    <!--
      Chrome needs byte-range support to seek inside large video files.
      IIS supports this natively for static files — no special config needed —
      but the headers below make it explicit and help with some edge cases.
    -->
    <httpProtocol>
      <customHeaders>
        <add name="Accept-Ranges" value="bytes" />
      </customHeaders>
    </httpProtocol>

    <!-- ── Security: allow video folder to be browsed for debugging ─────── -->
    <!-- Remove or set enabled="false" in production -->
    <directoryBrowse enabled="false" />

    <!-- ── Remove upload size limit (not strictly needed for static sites, -->
    <!--    but prevents 404/500 errors on very large range requests)       -->
    <security>
      <requestFiltering>
        <!-- Allow large files; default IIS limit is 30 MB -->
        <requestLimits maxAllowedContentLength="4294967295" />
      </requestFiltering>
    </security>

  </system.webServer>

</configuration>
